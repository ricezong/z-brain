# ==================== 开发环境配置 ====================
spring:
  # PostgreSQL 数据源
  datasource:
    driver-class-name: org.postgresql.Driver
    url: jdbc:postgresql://124.223.110.114:15432/zbrain?stringtype=unspecified&reWriteBatchedInserts=true
    username: postgres
    password: ${DB_PASSWORD:your-database-password}
    hikari:
      maximum-pool-size: 20
      minimum-idle: 5
      idle-timeout: 30000
      max-lifetime: 1800000
      connection-timeout: 30000
      pool-name: ZBrainHikariPool

  # Redis
  data:
    redis:
      host: 124.223.110.114
      port: 16379
      database: 0
      timeout: 3000ms
      lettuce:
        pool:
          max-active: 16
          max-idle: 8
          min-idle: 2
          max-wait: 3000ms

logging:
  level:
    com.zbrain: DEBUG
