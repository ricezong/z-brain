<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kong.eon.persistence.mapper.AgentContextSummaryMapper">

    <resultMap id="BaseResultMap" type="cn.kong.eon.persistence.entity.AgentContextSummary">
        <id     column="id"              property="id"/>
        <result column="session_id"      property="sessionId"/>
        <result column="summary"         property="summary"/>
        <result column="base_message_id" property="baseMessageId"/>
        <result column="create_time"     property="createTime"/>
        <result column="update_time"     property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, session_id, summary, base_message_id, create_time, update_time
    </sql>

    <insert id="insert" parameterType="cn.kong.eon.persistence.entity.AgentContextSummary" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO agent_context_summary (session_id, summary, base_message_id)
        VALUES (#{sessionId}, #{summary}, #{baseMessageId})
    </insert>

    <select id="selectLatestBySessionId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_context_summary
        WHERE session_id = #{sessionId}
        ORDER BY id DESC
        LIMIT 1
    </select>

</mapper>

