<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kong.zbrain.mapper.SysPromptMapper">

    <resultMap id="BaseResultMap" type="cn.kong.zbrain.entity.SysPrompt">
        <id     column="id"          property="id"/>
        <result column="prompt_key"  property="promptKey"/>
        <result column="name"        property="name"/>
        <result column="description" property="description"/>
        <result column="content"     property="content"/>
        <result column="is_active"   property="isActive"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, prompt_key, name, description, content, is_active, create_time, update_time
    </sql>

    <insert id="insert" parameterType="cn.kong.zbrain.entity.SysPrompt" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_prompt (prompt_key, name, description, content, is_active)
        VALUES (#{promptKey}, #{name}, #{description}, #{content}, COALESCE(#{isActive}, TRUE))
    </insert>

    <update id="update" parameterType="cn.kong.zbrain.entity.SysPrompt">
        UPDATE sys_prompt
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="content != null">content = #{content},</if>
            <if test="isActive != null">is_active = #{isActive},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_prompt WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_prompt
        WHERE id = #{id}
    </select>

    <select id="selectByKey" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_prompt
        WHERE prompt_key = #{promptKey}
          AND is_active = TRUE
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_prompt
        ORDER BY id ASC
    </select>

</mapper>
