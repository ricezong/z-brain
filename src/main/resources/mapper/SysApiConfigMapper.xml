<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kong.zbrain.mapper.SysApiConfigMapper">

    <resultMap id="BaseResultMap" type="cn.kong.zbrain.entity.SysApiConfig">
        <id     column="id"           property="id"/>
        <result column="config_type"  property="configType"/>
        <result column="enabled"      property="enabled"/>
        <result column="api_key"      property="apiKey"/>
        <result column="base_url"     property="baseUrl"/>
        <result column="config"       property="config"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, config_type, enabled, api_key, base_url, config
    </sql>

    <select id="selectByType" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_api_config
        WHERE config_type = #{configType}
        LIMIT 1
    </select>

    <insert id="insert" parameterType="cn.kong.zbrain.entity.SysApiConfig" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_api_config
            (config_type, enabled, api_key, base_url, config)
        VALUES
            (#{configType}, COALESCE(#{enabled}, TRUE), #{apiKey}, #{baseUrl},
             #{config}::jsonb)
    </insert>

    <update id="update" parameterType="cn.kong.zbrain.entity.SysApiConfig">
        UPDATE sys_api_config
        <set>
            <if test="enabled != null">enabled = #{enabled},</if>
            <if test="apiKey != null">api_key = #{apiKey},</if>
            <if test="baseUrl != null">base_url = #{baseUrl},</if>
            <if test="config != null">config = #{config}::jsonb,</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>
