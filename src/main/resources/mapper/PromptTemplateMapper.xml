<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kong.zbrain.mapper.PromptTemplateMapper">

    <resultMap id="BaseResultMap" type="cn.kong.zbrain.entity.PromptTemplate">
        <id     column="id"              property="id"/>
        <result column="kb_id"           property="kbId"/>
        <result column="name"            property="name"/>
        <result column="system_prompt"   property="systemPrompt"/>
        <result column="user_prompt"     property="userPrompt"/>
        <result column="is_default"      property="isDefault"/>
        <result column="create_time"     property="createTime"/>
        <result column="update_time"     property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, kb_id, name, system_prompt, user_prompt, is_default, create_time, update_time
    </sql>

    <insert id="insert" parameterType="cn.kong.zbrain.entity.PromptTemplate" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO kb_prompt_template
            (kb_id, name, system_prompt, user_prompt, is_default)
        VALUES
            (#{kbId}, #{name}, #{systemPrompt}, #{userPrompt}, COALESCE(#{isDefault}, FALSE))
    </insert>

    <update id="update" parameterType="cn.kong.zbrain.entity.PromptTemplate">
        UPDATE kb_prompt_template
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="systemPrompt != null">system_prompt = #{systemPrompt},</if>
            <if test="userPrompt != null">user_prompt = #{userPrompt},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM kb_prompt_template WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM kb_prompt_template
        WHERE id = #{id}
    </select>

    <select id="selectByKbId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM kb_prompt_template
        WHERE kb_id = #{kbId} OR (kb_id IS NULL AND is_default = TRUE)
        ORDER BY is_default DESC, create_time DESC
        LIMIT 1
    </select>

    <select id="selectDefault" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM kb_prompt_template
        WHERE is_default = TRUE
        ORDER BY create_time DESC
        LIMIT 1
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM kb_prompt_template
        <where>
            <if test="kbId != null">
                AND (kb_id = #{kbId} OR kb_id IS NULL)
            </if>
        </where>
        ORDER BY is_default DESC, create_time DESC
    </select>

</mapper>
