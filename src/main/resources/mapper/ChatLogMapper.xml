<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kong.zbrain.mapper.ChatLogMapper">

    <resultMap id="BaseResultMap" type="cn.kong.zbrain.entity.ChatLog">
        <id     column="id"                property="id"/>
        <result column="session_id"        property="sessionId"/>
        <result column="kb_id"             property="kbId"/>
        <result column="user_id"           property="userId"/>
        <result column="query"             property="query"/>
        <result column="rewritten_query"   property="rewrittenQuery"/>
        <result column="hyde_answer"       property="hydeAnswer"/>
        <result column="answer"            property="answer"/>
        <result column="hit_chunk_ids"     property="hitChunkIds"/>
        <result column="retrieval_info"    property="retrievalInfo"/>
        <result column="token_usage"       property="tokenUsage"/>
        <result column="cost_time_ms"      property="costTimeMs"/>
        <result column="create_time"       property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, session_id, kb_id, user_id, query, rewritten_query, hyde_answer, answer,
        hit_chunk_ids, retrieval_info, token_usage, cost_time_ms, create_time
    </sql>

    <insert id="insert" parameterType="cn.kong.zbrain.entity.ChatLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO kb_chat_log
            (session_id, kb_id, user_id, query, rewritten_query, hyde_answer, answer,
             hit_chunk_ids, retrieval_info, token_usage, cost_time_ms)
        VALUES
            (#{sessionId}, #{kbId}, #{userId}, #{query}, #{rewrittenQuery}, #{hydeAnswer}, #{answer},
             <choose>
                 <when test="hitChunkIds != null">#{hitChunkIds}::jsonb</when>
                 <otherwise>NULL</otherwise>
             </choose>,
             <choose>
                 <when test="retrievalInfo != null">#{retrievalInfo}::jsonb</when>
                 <otherwise>NULL</otherwise>
             </choose>,
             <choose>
                 <when test="tokenUsage != null">#{tokenUsage}::jsonb</when>
                 <otherwise>NULL</otherwise>
             </choose>,
             #{costTimeMs})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM kb_chat_log
        WHERE id = #{id}
    </select>

    <select id="selectBySessionId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM kb_chat_log
        WHERE session_id = #{sessionId}
        ORDER BY create_time ASC
    </select>

    <select id="selectByKbId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM kb_chat_log
        WHERE kb_id = #{kbId}
        ORDER BY create_time DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByKbId" resultType="long">
        SELECT COUNT(1) FROM kb_chat_log WHERE kb_id = #{kbId}
    </select>

</mapper>
